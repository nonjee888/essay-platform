---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getPublishedEssays } from '../lib/essays';

const essays = await getPublishedEssays();
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<p class="intro">{SITE_DESCRIPTION}</p>
			<ul class="essays">
				{
					essays.map((essay) => (
						<li>
							<a href={`/blog/${essay.id}/`}>
								<span class="title">{essay.data.title}</span>
								<FormattedDate date={essay.data.pubDate} />
							</a>
						</li>
					))
				}
			</ul>
		</main>
		<Footer />
	</body>
</html>

<style>
	.intro {
		color: rgb(var(--gray));
		font-style: italic;
		margin-bottom: 3rem;
	}
	.essays {
		list-style: none;
		margin: 0;
		padding: 0;
	}
	.essays li {
		border-bottom: 1px solid rgb(var(--gray-light));
	}
	.essays a {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		gap: 1rem;
		padding: 1rem 0;
		color: rgb(var(--black));
		text-decoration: none;
	}
	.essays a:hover .title {
		color: var(--accent);
	}
	.essays .title {
		font-size: 1.4rem;
	}
	.essays time {
		color: rgb(var(--gray));
		font-size: 0.9rem;
		white-space: nowrap;
	}
</style>
